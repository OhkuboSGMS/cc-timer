# Anthropic API key (required)
ANTHROPIC_API_KEY=your-api-key

# Webhook URL for notifications (required)
CCTIMER_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Data directory for state/logs/config (default: ~/.cctimer)
CCTIMER_DATA_DIR=

# Working directory for CC agent (default: current directory)
CCTIMER_WORK_DIR=

# Default interval in minutes if CC doesn't specify (default: 30)
CCTIMER_DEFAULT_INTERVAL_MIN=30

# Maximum interval in minutes (default: 1440 = 24h)
CCTIMER_MAX_INTERVAL_MIN=1440

# Minimum interval in minutes (default: 5)
CCTIMER_MIN_INTERVAL_MIN=5
